# ──────────────────────────────────────────────
# Fake News Tracker - Environment Variables
# 이 파일을 .env 로 복사한 뒤 실제 키를 입력하세요
# cp .env.example .env
# ──────────────────────────────────────────────

# ── Naver Search API ──
# 발급: https://developers.naver.com/apps/#/register
# 애플리케이션 등록 → 검색 API 선택
NAVER_CLIENT_ID=OgQGapQAKHV7RIesSjYm
NAVER_CLIENT_SECRET=bXQ_4U1FDZ

# ── Google Fact Check API ──
# 발급: https://console.cloud.google.com/apis/credentials
# Fact Check Tools API 사용 설정 필요
GOOGLE_API_KEY=AIzaSyA6VkcqN8gCkzNZ2OTTrpowzRAm4eebqGI

# ── Google Custom Search API (선택) ──
# 글로벌 뉴스 검색용. 없으면 Naver API만 사용
# 발급: https://programmablesearchengine.google.com/
# GOOGLE_CSE_ID=
# GOOGLE_CSE_API_KEY=

# ── Server Config ──
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Crawling Config ──
MAX_CANDIDATES=30
SIMILARITY_THRESHOLD=0.4
REQUEST_TIMEOUT=15
